# Stalwart — segredos de runtime (PoC)
# Copiar para /opt/stalwart/.env na VPS e preencher. NUNCA commitar o .env real.
#
# Admin/fallback inicial do painel. Trocar a senha por uma forte.
# (Alternativa: sem esta env, o Stalwart imprime uma senha de bootstrap nos logs.)
STALWART_RECOVERY_ADMIN=admin:TROCAR_POR_SENHA_FORTE

# URL pública do painel (fica atrás do Traefik). Usada em links/redirects.
STALWART_PUBLIC_URL=https://mail-admin.virtuetech.com.br

# Observação: o TOKEN do Cloudflare (ACME DNS-01) NÃO vai aqui — ele é inserido
# na UI do Stalwart (Settings > Server > TLS > ACME Providers) após o primeiro login.
